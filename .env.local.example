# Supabase — create a project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Legacy anon JWT OR new publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Public site URL for auth email links (invite, password reset)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Service role / secret key: required for inviting users (server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# REQUIRED for production and private-server deploys — real Supabase auth, no mock data.
# Set to true only for local demos with the user picker and sample data.
NEXT_PUBLIC_FLOW_DEMO_MODE=false

# Optional — injected at build if unset (format YYYY.MM.DD or YYYY-MM-DD)
# NEXT_PUBLIC_APP_BUILD_DATE=2026.06.16
# NEXT_PUBLIC_APP_ENVIRONMENT=production
# NEXT_PUBLIC_APP_DEPLOYMENT_SOURCE=main

# --- Setup scripts (npm run setup:supabase) — server/local only, never commit real values ---
# Database password (Settings → Database) — required to run migrations via setup script
SUPABASE_DB_PASSWORD=your-database-password

# Optional pooler override if auto-detection fails
# SUPABASE_DB_POOLER_HOST=aws-1-us-west-2.pooler.supabase.com

# Primary admin account — preserved on setup; use your real work email
FLOW_ADMIN_EMAIL=you@company.com
FLOW_ADMIN_PASSWORD=your-secure-password
