# Supabase — create a project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public site URL for auth email links (invite, password reset)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Service role: required for inviting users (server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Demo mode: set to false (or remove) when using Supabase auth
NEXT_PUBLIC_FLOW_DEMO_MODE=false
