{
  "name": "flow",
  "version": "0.8.3-beta",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:supabase": "node --env-file=.env.local scripts/check-supabase.mjs",
    "verify:supabase": "node --env-file=.env.local scripts/verify-supabase.mjs",
    "verify:production": "node scripts/verify-production-link.mjs",
    "audit:production-data": "node --env-file=.env.local scripts/audit-production-data.mjs",
    "setup:supabase": "node --env-file=.env.local scripts/setup-supabase.mjs",
    "migrate:all": "node --env-file=.env.local scripts/run-all-migrations.mjs",
    "migrate:pending": "node --env-file=.env.local scripts/run-migration-files.mjs 031_program_structure_mode.sql 032_work_package_tracking_flags.sql 033_platform_persistence.sql",
    "test:e2e": "playwright test",
    "enable:signup": "node --env-file=.env.local scripts/enable-employee-signup.mjs",
    "reset:admin": "node --env-file=.env.local scripts/reset-admin-password.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "pg": "^8.21.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.6"
  }
