# =============================================================================
# Flow — environment variables (copy to .env.local for dev, Vercel dashboard for prod)
# =============================================================================
# Never commit real secrets. Use placeholder values only in this file.
#
# Vercel: Project → Settings → Environment Variables
#   - Set all variables marked [required] for Production (and Preview if using Supabase there).
#   - Set NEXT_PUBLIC_SITE_URL to your production domain (custom domain or *.vercel.app).
#
# Supabase: Authentication → URL configuration
#   Site URL (production): https://flowproduction.space  — NOT localhost
#   Redirect URLs — add all of:
#     https://flowproduction.space/auth/callback
#     https://flowproduction.space/auth/callback/**
#     https://flowproduction.space/auth/confirm
#     https://flowproduction.space/auth/confirm/**
#   For local dev also add:
#     http://localhost:3000/auth/callback
#     http://localhost:3000/auth/confirm
#
# File uploads on Vercel are capped at ~4 MB per server action (platform limit).
# Self-hosted / private server builds allow larger limits (10–25 MB).
# =============================================================================

# --- Supabase (required for production) ----------------------------------------

# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Settings → API → anon public key (legacy JWT) OR publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Settings → API → service_role / secret key — server-only; required for user invites
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# --- App mode (required) -------------------------------------------------------

# Public URL for auth email links (invite, password reset, email confirmation).
# Production: https://your-domain.com (no trailing slash)
# Vercel preview: optional; VERCEL_URL is used as fallback when unset.
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# MUST be false in production. true = demo user picker + mock data (local only).
NEXT_PUBLIC_FLOW_DEMO_MODE=false

# Organization timezone for shift clocks, wrap-ups, and "today" boundaries.
# Production (Vercel) runs in UTC — set this to your team's IANA zone.
# Example: America/Chicago, America/New_York, America/Los_Angeles
NEXT_PUBLIC_FLOW_TIMEZONE=America/Chicago

# --- Optional display / build metadata -----------------------------------------

# NEXT_PUBLIC_APP_BUILD_DATE=2026.06.22
# NEXT_PUBLIC_APP_ENVIRONMENT=production
# NEXT_PUBLIC_APP_DEPLOYMENT_SOURCE=main

# Upload limits for non-Vercel hosts (bytes). Ignored on Vercel builds (4 MB cap).
# NEXT_PUBLIC_MAX_TASK_FILE_BYTES=10485760
# NEXT_PUBLIC_MAX_COMPANY_DOCUMENT_BYTES=26214400
# NEXT_PUBLIC_MAX_FEEDBACK_ATTACHMENT_BYTES=10485760

# --- Setup scripts only (npm run setup:supabase) — never expose in Vercel ------

# Database password (Settings → Database) — migrations via setup script
# SUPABASE_DB_PASSWORD=your-database-password

# Optional pooler override if auto-detection fails
# SUPABASE_DB_POOLER_HOST=aws-1-us-west-2.pooler.supabase.com

# Primary admin for setup script — not used at runtime by the web app
# FLOW_ADMIN_EMAIL=you@company.com
# FLOW_ADMIN_PASSWORD=your-secure-password
